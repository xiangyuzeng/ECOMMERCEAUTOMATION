# =============================================================================
# 肯葳科技亚马逊自动运营系统 — 环境变量配置
# 使用方法：复制此文件为 .env 并填入你的值
#   Mac/Linux:  cp .env.example .env
#   Windows:    copy .env.example .env
# =============================================================================

# --- AdsPower 浏览器自动化 ---
# AdsPower 运行在你的电脑上（不在 Docker 容器内）
# Docker 容器通过 host.docker.internal 访问你的电脑
# 如果不使用 Docker，保持 localhost 即可
ADSPOWER_API_URL=http://host.docker.internal:50325

# 在 AdsPower → 设置 → API 中获取 API Key
ADSPOWER_API_KEY=your_api_key_here

# 在 AdsPower → 浏览器配置列表中获取 Profile ID
ADSPOWER_PROFILE_ID=your_profile_id

# --- 应用配置 ---
NODE_ENV=production
PORT=3000
