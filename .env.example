# =============================================================================
# ECOMMERCEAUTOMATION — Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# AdsPower browser automation (runs on host machine)
ADSPOWER_API_URL=http://localhost:50325
ADSPOWER_API_KEY=your_api_key_here
ADSPOWER_PROFILE_ID=your_profile_id

# Application
NODE_ENV=production
PORT=3000
