#!/bin/bash
# =============================================================================
# 肯葳科技亚马逊自动运营系统 — Mac Desktop Launcher
# Double-click this .app to start the system. No terminal needed.
# =============================================================================

# Ensure Docker and other tools are in PATH (macOS .app doesn't inherit shell PATH)
export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

# Resolve project root (this script is at desktop/mac/App/Contents/MacOS/)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/../../../../.." && pwd)"

# Helper: show native macOS dialog
dialog() {
    osascript -e "display dialog \"$1\" with title \"肯葳自动运营系统\" buttons {\"$2\"} default button 1 with icon note" 2>/dev/null
}

dialog_error() {
    osascript -e "display dialog \"$1\" with title \"肯葳自动运营系统\" buttons {\"确定\"} default button 1 with icon stop" 2>/dev/null
}

dialog_yesno() {
    osascript -e "display dialog \"$1\" with title \"肯葳自动运营系统\" buttons {\"取消\", \"$2\"} default button 2" 2>/dev/null
    return $?
}

# Helper: show notification
notify() {
    osascript -e "display notification \"$1\" with title \"肯葳自动运营系统\"" 2>/dev/null
}

# --- Step 1: Check Docker ---
if ! command -v docker &>/dev/null; then
    dialog_error "Docker 未安装。\n\n请先安装 Docker Desktop：\nhttps://www.docker.com/products/docker-desktop/\n\n安装完成后重新打开此应用。"
    open "https://www.docker.com/products/docker-desktop/"
    exit 1
fi

# --- Step 2: Start Docker if not running ---
if ! docker info &>/dev/null 2>&1; then
    notify "正在启动 Docker Desktop..."
    open -a "Docker" 2>/dev/null

    # Wait up to 60 seconds for Docker to start
    WAIT=0
    while ! docker info &>/dev/null 2>&1; do
        sleep 2
        WAIT=$((WAIT + 2))
        if [ $WAIT -ge 60 ]; then
            dialog_error "Docker Desktop 启动超时。\n\n请手动打开 Docker Desktop，等待其完全启动后，再重新打开此应用。"
            exit 1
        fi
    done
fi

# --- Step 3: Create directories ---
cd "$PROJECT_DIR" || { dialog_error "无法找到项目目录：\n$PROJECT_DIR"; exit 1; }
mkdir -p data inputs/sellersprite inputs/seller-central outputs processed logs

# --- Step 4: Generate .env from setup.json if exists ---
if [ -f data/setup.json ]; then
    # Read setup.json and generate .env
    python3 -c "
import json
setup = json.load(open('data/setup.json'))
with open('.env', 'w') as f:
    f.write('# Auto-generated by desktop launcher\n')
    f.write(f'ADSPOWER_API_URL={setup.get(\"api_url\", \"http://host.docker.internal:50325\")}\n')
    f.write(f'ADSPOWER_API_KEY={setup.get(\"api_key\", \"\")}\n')
    f.write(f'ADSPOWER_PROFILE_ID={setup.get(\"profile_id\", \"\")}\n')
    f.write('NODE_ENV=production\n')
    f.write('PORT=3000\n')
    import os
    f.write(f'DOWNLOAD_DIR_HOST={os.getcwd()}/downloads\n')
" 2>/dev/null
elif [ ! -f .env ]; then
    # First run — create minimal .env (setup wizard will handle the rest)
    cat > .env << 'ENVEOF'
ADSPOWER_API_URL=http://host.docker.internal:50325
ADSPOWER_API_KEY=
ADSPOWER_PROFILE_ID=
NODE_ENV=production
PORT=3000
ENVEOF
fi

# --- Step 5: Start Docker container ---
notify "正在启动系统..."

# Check if container is already running
if docker compose ps --format json 2>/dev/null | grep -q '"running"'; then
    # Already running — just open browser
    open "http://localhost:3000"
    notify "系统已在运行中"
    exit 0
fi

# Start container (build if needed)
docker compose up -d --build 2>&1 | tail -5

# --- Step 6: Wait for health check ---
WAIT=0
MAX_WAIT=180  # 3 minutes for first build
while ! curl -sf http://localhost:3000/api/status >/dev/null 2>&1; do
    sleep 3
    WAIT=$((WAIT + 3))
    if [ $WAIT -ge $MAX_WAIT ]; then
        dialog_error "系统启动超时。\n\n可能的原因：\n1. Docker 资源不足\n2. 端口 3000 被占用\n\n请在终端运行以下命令查看日志：\ncd $PROJECT_DIR && docker compose logs"
        exit 1
    fi
done

# --- Step 7: Open browser ---
open "http://localhost:3000"
notify "系统启动成功！浏览器已打开。"
